#!/bin/bash
# tokensaveoptimizer CLI вЂ” Enhanced Edition
# https://github.com/Basharlouzon/Token-save---optimizer

VERSION="2.0.0"

# в”Ђв”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GREEN='\033[0;32m'; BGREEN='\033[1;32m'
BLUE='\033[0;34m';  BBLUE='\033[1;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m';  BCYAN='\033[1;36m'
RED='\033[0;31m';   BRED='\033[1;31m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'; DIM='\033[2m'
NC='\033[0m'

# в”Ђв”Ђв”Ђ Cost per 1M tokens (USD) вЂ” update as needed в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
COST_PER_1M=3.00   # Claude Sonnet baseline

# в”Ђв”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
draw_bar() {
    local pct=$1   # 0-100
    local width=40
    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))
    printf "${GREEN}"
    for ((i=0; i<filled; i++)); do printf "в–€"; done
    printf "${DIM}${NC}"
    for ((i=0; i<empty; i++)); do printf "в–‘"; done
    printf "${NC}"
}

fmt_num() { printf "%'d" "$1"; }

cost_usd() {
    # bc-free integer math: tokens * 3 / 1,000,000  в†’ cents precision
    local t=$1
    echo "$(echo "scale=4; $t * $COST_PER_1M / 1000000" | bc 2>/dev/null || echo "0")"
}

detect_tools() {
    local found=()
    [ -f ".claudecode" ]  && found+=("Claude Code")
    [ -f ".clinerules" ]  && found+=("Cline")
    [ -f ".roomodes" ]    && found+=("Roo Code")
    [ -f ".kilorules" ]   && found+=("Kilo")
    [ -f ".geminirules" ] && found+=("Gemini CLI")
    [ -f ".opencode" ]    && found+=("Open Code")
    echo "${found[@]}"
}

load_or_init_stats() {
    STATS_FILE=".ai-memory/optimizer-stats.json"
    if [ -f "$STATS_FILE" ]; then
        SESSIONS=$(grep -o '"sessions":[0-9]*' "$STATS_FILE" | grep -o '[0-9]*' || echo 0)
        CUMULATIVE_SAVED=$(grep -o '"cumulative_saved":[0-9]*' "$STATS_FILE" | grep -o '[0-9]*' || echo 0)
        INSTALL_DATE=$(grep -o '"installed":"[^"]*"' "$STATS_FILE" | cut -d'"' -f4 || echo "unknown")
    else
        SESSIONS=0; CUMULATIVE_SAVED=0; INSTALL_DATE=$(date +"%Y-%m-%d")
    fi
}

save_stats() {
    local new_sessions=$(( SESSIONS + 1 ))
    local new_saved=$(( CUMULATIVE_SAVED + SAVED_TOKENS ))
    cat > ".ai-memory/optimizer-stats.json" << EOF
{
  "version": "$VERSION",
  "installed": "$INSTALL_DATE",
  "sessions": $new_sessions,
  "cumulative_saved": $new_saved,
  "last_run": "$(date +"%Y-%m-%d %H:%M")"
}
EOF
}

# в”Ђв”Ђв”Ђ DASHBOARD в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
show_dashboard() {
    clear
    echo -e "${BBLUE}"
    echo "  в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в•—  в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в•—   в–€в–€в•—"
    echo "     в–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•‘ в–€в–€в•”в•ќв–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в–€в–€в•—  в–€в–€в•‘"
    echo "     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в•”в•ќ в–€в–€в–€в–€в–€в•—  в–€в–€в•”в–€в–€в•— в–€в–€в•‘"
    echo "     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв–€в–€в•— в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•‘в•љв–€в–€в•—в–€в–€в•‘"
    echo "     в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘ в•љв–€в–€в–€в–€в•‘"
    echo "     в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ"
    echo -e "${NC}${DIM}     Save Optimizer  v$VERSION${NC}  ${DIM}github.com/Basharlouzon/Token-save---optimizer${NC}"
    echo ""

    if [ ! -d ".ai-memory" ]; then
        echo -e "  ${YELLOW}вљ   Not initialized in this project.${NC}"
        echo -e "  Run ${CYAN}tokensaveoptimizer install${NC} to get started.\n"
        _show_commands
        return
    fi

    load_or_init_stats

    # в”Ђв”Ђ Scan current project в”Ђв”Ђ
    RAW_WORDS=0
    if command -v rg &>/dev/null; then
        RAW_WORDS=$(rg --files 2>/dev/null | grep -v '\.ai-memory' | xargs wc -w 2>/dev/null | tail -1 | awk '{print $1}')
    else
        RAW_WORDS=$(find . -type f -not -path '*/\.*' -not -path '*/node_modules/*' \
          -not -path '*/build/*' -not -path '*/dist/*' 2>/dev/null | xargs wc -w 2>/dev/null | tail -1 | awk '{print $1}')
    fi
    [ -z "$RAW_WORDS" ] && RAW_WORDS=0

    MAP_WORDS=0
    [ -f ".ai-memory/repo-map.txt" ] && MAP_WORDS=$(wc -w < ".ai-memory/repo-map.txt")

    RAW_TOKENS=$(( RAW_WORDS * 13 / 10 ))
    MAP_TOKENS=$(( MAP_WORDS * 13 / 10 ))
    SAVED_TOKENS=$(( RAW_TOKENS - MAP_TOKENS ))
    [ $SAVED_TOKENS -lt 0 ] && SAVED_TOKENS=0

    PCT=0
    [ $RAW_TOKENS -gt 0 ] && PCT=$(( SAVED_TOKENS * 100 / RAW_TOKENS ))

    # Save updated stats
    save_stats
    NEW_CUMULATIVE=$(( CUMULATIVE_SAVED + SAVED_TOKENS ))
    NEW_SESSIONS=$(( SESSIONS + 1 ))

    COST_SAVED=$(cost_usd $SAVED_TOKENS)
    COST_CUM=$(cost_usd $NEW_CUMULATIVE)

    # в”Ђв”Ђ Project Info в”Ђв”Ђ
    local TOOLS=$(detect_tools)
    echo -e "  ${BOLD}рџ“Ѓ Project:${NC}  ${CYAN}$(basename $(pwd))${NC}    ${DIM}Installed: $INSTALL_DATE${NC}"
    if [ -n "$TOOLS" ]; then
        echo -e "  ${BOLD}рџ¤– Active agents:${NC} ${GREEN}$TOOLS${NC}"
    fi
    echo ""

    # в”Ђв”Ђ Token Table в”Ђв”Ђ
    echo -e "  ${BOLD}в”Ђв”Ђ THIS SESSION в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    printf "  %-32s %s\n" "Full project scan (tokens):" "$(echo -e "${RED}$(fmt_num $RAW_TOKENS)${NC}")"
    printf "  %-32s %s\n" "Optimized map (tokens):"     "$(echo -e "${GREEN}$(fmt_num $MAP_TOKENS)${NC}")"
    printf "  %-32s %s\n" "Tokens saved:"               "$(echo -e "${YELLOW}$(fmt_num $SAVED_TOKENS)${NC}  (~${PCT}%)")"
    printf "  %-32s %s\n" "Est. cost saved:"            "$(echo -e "${BGREEN}\$${COST_SAVED}${NC}")"
    echo ""

    # в”Ђв”Ђ Visual bar в”Ђв”Ђ
    echo -ne "  Reduction: ["
    draw_bar $PCT
    echo -e "]  ${YELLOW}${PCT}%${NC}"
    echo ""

    # в”Ђв”Ђ Cumulative stats в”Ђв”Ђ
    echo -e "  ${BOLD}в”Ђв”Ђ ALL TIME в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    printf "  %-32s %s\n" "Total AI sessions:"          "$(echo -e "${CYAN}${NEW_SESSIONS}${NC}")"
    printf "  %-32s %s\n" "Total tokens saved:"         "$(echo -e "${BGREEN}$(fmt_num $NEW_CUMULATIVE)${NC}")"
    printf "  %-32s %s\n" "Total cost saved (est.):"   "$(echo -e "${BGREEN}\$${COST_CUM}${NC}")"
    echo ""

    # в”Ђв”Ђ Memory state в”Ђв”Ђ
    if [ -f ".ai-memory/state.md" ]; then
        local last_line=$(grep -m1 "^\!" ".ai-memory/state.md" 2>/dev/null || echo "")
        [ -n "$last_line" ] && echo -e "  ${DIM}рџ’¬ Last memory note: $last_line${NC}\n"
    fi

    _show_commands
}

_show_commands() {
    echo -e "  ${BOLD}в”Ђв”Ђ COMMANDS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo -e "  ${CYAN}install${NC}   Interactive setup wizard for this project"
    echo -e "  ${CYAN}stats${NC}     Detailed token savings report"
    echo -e "  ${CYAN}reset${NC}     Clear cumulative stats for this project"
    echo -e "  ${CYAN}update${NC}    Pull latest version from GitHub"
    echo -e "  ${CYAN}help${NC}      Show this screen"
    echo ""
}

# в”Ђв”Ђв”Ђ INSTALL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
run_install() {
    echo -e "${BBLUE}======================================================${NC}"
    echo -e "${BGREEN}рџљЂ Token Save Optimizer вЂ” Project Setup${NC}"
    echo -e "${BBLUE}======================================================${NC}\n"

    RULES=$(cat << 'RULES_EOF'

# ==========================================
# CONTEXT OPTIMIZER & TOKEN SAVER RULES
# ==========================================
- **Search Diet**: Do not read full files blindly. Check file size first. Use lightweight search to find filenames before reading. Only read specific line ranges required.
- **Smart Init**: If you need to explore the project, do not run `ls -R`. Instead, run `bash .ai-memory/scripts/init-smart-search.sh .` and read `.ai-memory/repo-map.txt`.
- **Memory Protocol**: Before acting, always read `.ai-memory/state.md`. Upon reaching a milestone or repeating actions, compress your current understanding into `.ai-memory/state.md` and explicitly command yourself to forget the prior raw context to save tokens.
- **Stop Duplication**: If you find yourself in a loop or re-reading the same files, STOP. Update the memory state and ask the user for clarification.
RULES_EOF
    )

    inject_rules() {
        local file=$1 name=$2
        if [ -f "$file" ]; then
            if ! grep -q "CONTEXT OPTIMIZER & TOKEN SAVER RULES" "$file"; then
                echo "$RULES" >> "$file"
                echo -e "  вњ… Updated ${CYAN}$name${NC} в†’ $file"
            else
                echo -e "  вљЎ ${YELLOW}$name${NC} already configured."
            fi
        else
            echo "$RULES" > "$file"
            echo -e "  вњ… Created ${GREEN}$name${NC} в†’ $file"
        fi
    }

    echo -e "Select AI tools to configure ${DIM}(space-separated numbers or 7 for ALL)${NC}:\n"
    echo -e "  1) Claude Code    (.claudecode)"
    echo -e "  2) Cline          (.clinerules)"
    echo -e "  3) Roo Code       (.roomodes)"
    echo -e "  4) Kilo           (.kilorules)"
    echo -e "  5) Gemini CLI     (.geminirules)"
    echo -e "  6) Open Code      (.opencode)"
    echo -e "  ${YELLOW}7) рџЋЇ ALL of them${NC}\n"

    [ -t 0 ] || exec < /dev/tty
    read -p "  Your selection: " selections

    echo ""
    echo -e "  ${BLUE}в¬‡  Downloading scripts...${NC}"
    mkdir -p .ai-memory/scripts
    curl -sSL "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/scripts/init-smart-search.sh" \
         -o .ai-memory/scripts/init-smart-search.sh
    chmod +x .ai-memory/scripts/init-smart-search.sh
    echo -e "  ${GREEN}вњ“ init-smart-search.sh ready${NC}\n"

    echo -e "  ${BLUE}вљ™  Injecting rules...${NC}"
    [[ " $selections " == *" 7 "* ]] && selections="1 2 3 4 5 6"

    for choice in $selections; do
        case $choice in
            1) inject_rules ".claudecode"  "Claude Code" ;;
            2) inject_rules ".clinerules"  "Cline" ;;
            3) inject_rules ".roomodes"    "Roo Code" ;;
            4) inject_rules ".kilorules"   "Kilo" ;;
            5) inject_rules ".geminirules" "Gemini CLI" ;;
            6) inject_rules ".opencode"    "Open Code" ;;
        esac
    done

    # Init repo map
    echo ""
    echo -e "  ${BLUE}рџ—є  Generating repo map...${NC}"
    bash .ai-memory/scripts/init-smart-search.sh . &>/dev/null
    echo -e "  ${GREEN}вњ“ .ai-memory/repo-map.txt generated${NC}"

    # Init stats file
    INSTALL_DATE=$(date +"%Y-%m-%d")
    mkdir -p .ai-memory
    cat > ".ai-memory/optimizer-stats.json" << EOF
{
  "version": "$VERSION",
  "installed": "$INSTALL_DATE",
  "sessions": 0,
  "cumulative_saved": 0,
  "last_run": "$INSTALL_DATE"
}
EOF

    echo ""
    echo -e "${BBLUE}======================================================${NC}"
    echo -e "${BGREEN}рџЋ‰ All done!${NC}"
    echo -e "  Run ${CYAN}tokensaveoptimizer${NC} to see your live token dashboard."
    echo -e "  Star the repo в­ђ  ${DIM}github.com/Basharlouzon/Token-save---optimizer${NC}"
    echo -e "${BBLUE}======================================================${NC}\n"
}

# в”Ђв”Ђв”Ђ STATS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
run_stats() {
    show_dashboard
}

# в”Ђв”Ђв”Ђ RESET в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
run_reset() {
    if [ -f ".ai-memory/optimizer-stats.json" ]; then
        rm ".ai-memory/optimizer-stats.json"
        echo -e "${GREEN}вњ… Cumulative stats cleared for this project.${NC}"
    else
        echo -e "${YELLOW}No stats file found.${NC}"
    fi
}

# в”Ђв”Ђв”Ђ UPDATE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
run_update() {
    echo -e "${BLUE}Pulling latest version from GitHub...${NC}"
    INSTALL_DIR=$(dirname "$(which tokensaveoptimizer)")
    sudo curl -sSL \
        "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/bin/tokensaveoptimizer" \
        -o "$INSTALL_DIR/tokensaveoptimizer"
    sudo chmod +x "$INSTALL_DIR/tokensaveoptimizer"
    echo -e "${GREEN}вњ… Updated to latest version!${NC}"
    tokensaveoptimizer --version
}

# в”Ђв”Ђв”Ђ VERSION в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
show_version() {
    echo "tokensaveoptimizer v$VERSION"
}

# в”Ђв”Ђв”Ђ ROUTER в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
case "$1" in
    install)          run_install ;;
    stats)            run_stats ;;
    reset)            run_reset ;;
    update)           run_update ;;
    --version|-v)     show_version ;;
    help|--help|-h)   show_dashboard ;;
    "")               show_dashboard ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_dashboard
        exit 1
        ;;
esac
