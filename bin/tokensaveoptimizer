#!/bin/bash
# tokensaveoptimizer CLI

VERSION="1.0.0"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m' # No Color

show_help() {
    echo -e "${BLUE}======================================================${NC}"
    echo -e "${GREEN}🧠 Token Save Optimizer (v$VERSION)${NC}"
    echo -e "${BLUE}======================================================${NC}"
    echo -e "Usage: tokensaveoptimizer [command]"
    echo ""
    echo -e "Commands:"
    echo -e "  ${CYAN}install${NC}   Launch the interactive installation wizard for the current project"
    echo -e "  ${CYAN}stats${NC}     View statistics on how many tokens have been saved in this project"
    echo -e "  ${CYAN}help${NC}      Show this help menu"
    echo ""
}

run_install() {
    echo -e "${BLUE}======================================================${NC}"
    echo -e "${GREEN}🚀 Welcome to Token Save Optimizer Installation! 🧠🔋${NC}"
    echo -e "${BLUE}======================================================${NC}"
    echo -e "This will configure your local project to prevent AI token waste."
    echo ""

    # The core rules block
    RULES=$(cat << 'EOF'

# ==========================================
# CONTEXT OPTIMIZER & TOKEN SAVER RULES
# ==========================================
- **Search Diet**: Do not read full files blindly. Check file size first. Use lightweight search to find filenames before reading. Only read specific line ranges required.
- **Smart Init**: If you need to explore the project, do not run `ls -R`. Instead, run `bash .ai-memory/scripts/init-smart-search.sh .` and read `.ai-memory/repo-map.txt`.
- **Memory Protocol**: Before acting, always read `.ai-memory/state.md`. Upon reaching a milestone or repeating actions, compress your current understanding into `.ai-memory/state.md` and explicitly command yourself to forget the prior raw context to save tokens.
- **Stop Duplication**: If you find yourself in a loop or re-reading the same files, STOP. Update the memory state and ask the user for clarification.
EOF
    )

    inject_rules() {
        local file=$1
        local name=$2
        if [ -f "$file" ]; then
            if ! grep -q "CONTEXT OPTIMIZER & TOKEN SAVER RULES" "$file"; then
                echo "$RULES" >> "$file"
                echo -e "✅ Updated ${CYAN}$name${NC} ($file)"
            else
                echo -e "⚡ ${YELLOW}$name${NC} ($file) already has the rules applied."
            fi
        else
            echo "$RULES" > "$file"
            echo -e "✅ Created ${GREEN}$name${NC} config ($file)"
        fi
    }

    echo -e "Which AI tools do you want to install this for in this project?"
    echo "Enter the numbers separated by spaces (e.g., 1 3 4), or 7 for ALL:"
    echo "  1) Claude Code (.claudecode)"
    echo "  2) Cline (.clinerules)"
    echo "  3) Roo Code (.roomodes)"
    echo "  4) Kilo (.kilorules)"
    echo "  5) Gemini CLI / Antigravity (.geminirules)"
    echo "  6) Open Code (.opencode)"
    echo "  7) 🎯 Install for ALL of them"
    echo ""

    # Check if we have terminal access for read
    if [ -t 0 ]; then
        read -p "Your selection: " selections
    else
        # fallback if piped
        exec < /dev/tty
        read -p "Your selection: " selections
    fi

    echo ""
    echo -e "${BLUE}Installing scripts...${NC}"
    mkdir -p .ai-memory/scripts

    curl -sSL "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/scripts/init-smart-search.sh" -o .ai-memory/scripts/init-smart-search.sh
    chmod +x .ai-memory/scripts/init-smart-search.sh

    echo -e "${BLUE}Applying rules...${NC}"

    if [[ " $selections " == *" 7 "* ]]; then
        selections="1 2 3 4 5 6"
    fi

    for choice in $selections; do
        case $choice in
            1) inject_rules ".claudecode" "Claude Code" ;;
            2) inject_rules ".clinerules" "Cline" ;;
            3) inject_rules ".roomodes" "Roo Code" ;;
            4) inject_rules ".kilorules" "Kilo" ;;
            5) inject_rules ".geminirules" "Gemini CLI" ;;
            6) inject_rules ".opencode" "Open Code" ;;
            *) ;;
        esac
    done

    echo ""
    echo -e "${GREEN}🎉 Installation Complete!${NC}"
    echo -e "${BLUE}======================================================${NC}"
    echo -e "${YELLOW}💡 HOW TO USE:${NC}"
    echo -e "1. You don't need to do anything! The AI will automatically read these rules."
    echo -e "2. The AI will now use ${CYAN}.ai-memory/scripts/init-smart-search.sh${NC} to explore your project."
    echo -e "3. To see how many tokens you have saved, run:"
    echo -e "   ${CYAN}tokensaveoptimizer stats${NC}"
    echo -e ""
    echo -e "For more details or to star the repo, visit:"
    echo -e "${CYAN}https://github.com/Basharlouzon/Token-save---optimizer${NC}"
    echo -e "${BLUE}======================================================${NC}"
}

run_stats() {
    echo -e "${BLUE}======================================================${NC}"
    echo -e "${GREEN}📊 Token Save Optimizer Statistics${NC}"
    echo -e "${BLUE}======================================================${NC}"

    if [ ! -d ".ai-memory" ]; then
        echo -e "${RED}Error: .ai-memory not found in this directory.${NC}"
        echo -e "Run '${CYAN}tokensaveoptimizer install${NC}' first to initialize the optimizer for this project."
        exit 1
    fi

    # Calculate total size of files (excluding ignored directories)
    echo -e "Scanning raw project files to calculate potential token cost..."
    
    # Simple cross-platform way to get rough word count of codebase
    RAW_WORDS=0
    if command -v rg &> /dev/null; then
        # If ripgrep is installed, use it for super fast counting
        RAW_WORDS=$(rg --files | grep -v '\.ai-memory' | xargs wc -w 2>/dev/null | tail -n 1 | awk '{print $1}')
    else
        RAW_WORDS=$(find . -type f -not -path "*/\.*" -not -path "*/node_modules/*" -not -path "*/build/*" -not -path "*/dist/*" | xargs wc -w 2>/dev/null | tail -n 1 | awk '{print $1}')
    fi

    if [ -z "$RAW_WORDS" ]; then RAW_WORDS=0; fi

    # Calculate repo-map size
    MAP_WORDS=0
    if [ -f ".ai-memory/repo-map.txt" ]; then
        MAP_WORDS=$(wc -w < .ai-memory/repo-map.txt)
    fi

    # 1 word ≈ 1.3 tokens
    RAW_TOKENS=$(( RAW_WORDS * 13 / 10 ))
    MAP_TOKENS=$(( MAP_WORDS * 13 / 10 ))
    SAVED_TOKENS=$(( RAW_TOKENS - MAP_TOKENS ))

    if [ $SAVED_TOKENS -lt 0 ]; then SAVED_TOKENS=0; fi

    echo -e "Raw Project Tokens (if AI read everything): ${RED}$(printf "%'d" $RAW_TOKENS)${NC}"
    echo -e "Optimized Repo Map Tokens:                  ${GREEN}$(printf "%'d" $MAP_TOKENS)${NC}"
    echo -e "------------------------------------------------------"
    echo -e "🔥 ${YELLOW}Total Tokens Saved per AI Exploration: ${GREEN}$(printf "%'d" $SAVED_TOKENS)${NC} 🔥"
    echo -e "------------------------------------------------------"
    echo -e "Every time your AI explores your project using the optimizer map instead of raw searching, you save ${CYAN}$(printf "%'d" $SAVED_TOKENS)${NC} tokens!"
    echo -e ""
}

case "$1" in
    install)
        run_install
        ;;
    stats)
        run_stats
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_help
        exit 1
        ;;
esac
