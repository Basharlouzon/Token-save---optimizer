    <script>
        function normalizeData(raw) {
            const d = raw && typeof raw === 'object' ? raw : {};
            const num = (v, fallback) => {
                const n = typeof v === 'number' ? v : parseFloat(v);
                return Number.isFinite(n) ? n : fallback;
            };
            return {
                projectName:     d.projectName     || '—',
                dateExported:    d.dateExported    || '',
                activeAgents:    d.activeAgents    || '',
                filesCount:      num(d.filesCount, 0),
                rawTokens:       num(d.rawTokens, 0),
                mapTokens:       num(d.mapTokens, 0),
                savedTokens:     num(d.savedTokens, 0),
                pct:             num(d.pct, 0),
                compRatio:       d.compRatio != null ? String(d.compRatio) : '0',
                costSaved:       d.costSaved != null ? String(d.costSaved) : '0',
                sessions:        num(d.sessions, 0),
                cumulativeSaved: num(d.cumulativeSaved, 0),
                costCum:         d.costCum != null ? String(d.costCum) : '0',
                history:         Array.isArray(d.history) ? d.history.filter(v => Number.isFinite(+v)).map(v => +v) : [],
                milestones:      Array.isArray(d.milestones) ? d.milestones : []
            };
        }
        function debounce(fn, ms) {
            let t;
            return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
        }
        const setText = (id, v) => {
            const el = document.getElementById(id);
            if (el) el.textContent = v;
        };

        document.addEventListener('DOMContentLoaded', () => {
            window.TOKENSO_DATA = normalizeData(window.TOKENSO_DATA);
            const data = window.TOKENSO_DATA;

            setText('dt-project', data.projectName);
            setText('dt-date', data.dateExported);
            setText('dt-files', data.filesCount);
            setText('dt-tools', data.activeAgents || 'None detected');

            setText('card-sessions', data.sessions);
            setText('card-tokens', data.cumulativeSaved.toLocaleString());
            setText('card-savings', '$' + parseFloat(data.costCum || 0).toFixed(2));
            setText('card-ratio', data.compRatio + 'x');

            setText('gauge-pct', data.pct + '%');
            setText('gauge-comp-lbl', data.compRatio + 'x');

            renderMilestones();
            drawSavingsChart();
            window.addEventListener('resize', debounce(drawSavingsChart, 120));
            drawGauge();
            
            const sliderRuns = document.getElementById('slider-runs');
            const sliderTokens = document.getElementById('slider-tokens');

            if (data.savedTokens > 0 && sliderTokens) {
                sliderTokens.value = Math.min(Math.max(data.savedTokens, 1000), 100000);
            }

            const modelButtons = document.querySelectorAll('.model-btn');
            modelButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    modelButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    selectedModel = btn.getAttribute('data-model');
                    updateROI();
                });
            });

            if (sliderRuns) sliderRuns.addEventListener('input', updateROI);
            if (sliderTokens) sliderTokens.addEventListener('input', updateROI);
            updateROI();
        });

        let _gaugeRunning = false;
        function drawGauge() {
            const pct = Math.max(0, Math.min(100, window.TOKENSO_DATA.pct));
            const bar = document.getElementById('gauge-bar');
            if (!bar || _gaugeRunning) return;
            _gaugeRunning = true;
            const circumference = 2 * Math.PI * 80;
            const offset = circumference - (pct / 100) * circumference;
            bar.setAttribute('aria-label', `Compression ratio gauge: ${pct}% saved`);
            bar.setAttribute('role', 'img');
            requestAnimationFrame(() => {
                bar.style.strokeDashoffset = offset;
                _gaugeRunning = false;
            });
        }

        function renderMilestones() {
            const milestones = window.TOKENSO_DATA.milestones;
            const container = document.getElementById('timeline-container');
            if (!container) return;
            container.textContent = '';
            if (!milestones || milestones.length === 0) {
                const empty = document.createElement('div');
                empty.style.cssText = 'text-align:center;padding:30px 10px;color:var(--text-dim);font-size:13px;';
                empty.innerHTML = 'No memory milestones recorded. Save one using <code>tokenso save "Milestone text"</code>';
                container.appendChild(empty);
                return;
            }
            const reversed = [...milestones].reverse();
            const frag = document.createDocumentFragment();
            reversed.forEach((ms, idx) => {
                const num = reversed.length - idx;
                const item = document.createElement('div');
                item.className = 'timeline-item';
                item.setAttribute('role', 'listitem');
                item.setAttribute('aria-label', `Milestone ${num}: ${ms}`);
                const dot = document.createElement('div');
                dot.className = 'timeline-dot';
                const card = document.createElement('div');
                card.className = 'timeline-card';
                const header = document.createElement('div');
                header.className = 'timeline-card-header';
                header.textContent = `Milestone #${num}`;
                const body = document.createElement('div');
                body.style.lineHeight = '1.4';
                body.textContent = String(ms);
                card.appendChild(header);
                card.appendChild(body);
                item.appendChild(dot);
                item.appendChild(card);
                frag.appendChild(item);
            });
            container.setAttribute('role', 'list');
            container.appendChild(frag);
        }
        
        // ROI Simulator engine
        const models = {
            sonnet: { name: 'Claude Sonnet 4', rate: 3.00 },
            opus: { name: 'Claude Opus 4', rate: 15.00 },
            gemini: { name: 'Gemini 2.5 Pro', rate: 1.25 },
            gpt4o: { name: 'GPT-4.1', rate: 2.00 }
        };
        let selectedModel = 'sonnet';
        
        function updateROI() {
            const sliderRuns = document.getElementById('slider-runs');
            const sliderTokens = document.getElementById('slider-tokens');
            const valRuns = document.getElementById('val-runs');
            const valTokens = document.getElementById('val-tokens');
            
            const runs = parseInt(sliderRuns.value);
            const tokens = parseInt(sliderTokens.value);
            const rate = models[selectedModel].rate;
            
            valRuns.textContent = runs;
            valTokens.textContent = tokens.toLocaleString();
            
            const dailySaved = runs * tokens;
            const dailyUsd = (dailySaved * rate) / 1000000;
            const monthlyUsd = dailyUsd * 30;
            const annualUsd = dailyUsd * 365;
            
            document.getElementById('roi-monthly').textContent = '$' + monthlyUsd.toFixed(2);
            document.getElementById('roi-annual').textContent = '$' + annualUsd.toFixed(2);
            
            // Equivalence
            const coffees = Math.floor(annualUsd / 5);
            document.getElementById('roi-coffees').textContent = '☕ Equivalent to ' + coffees.toLocaleString() + ' cups of specialty coffee saved per year!';
            const VPSMonths = Math.floor(annualUsd / 12);
            document.getElementById('roi-server').textContent = '🖥️ Equivalent to ' + VPSMonths.toLocaleString() + ' months of modern VPS hosting paid off!';
        }
        
        // SVG Spline Line Chart drawing helper (memoized on history+width)
        let _chartMemo = '';
        function drawSavingsChart() {
            const history = window.TOKENSO_DATA.history;
            const container = document.getElementById('chart-container');
            if (!container) return;
            if (!history || history.length === 0) {
                container.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-dim);font-size:13px;">No historical runs recorded. Run <code>tokenso save</code> to track.</div>`;
                _chartMemo = '';
                return;
            }

            const width = container.clientWidth || 550;
            if (width === 0) return;
            const memoKey = history.join(',') + '|' + width;
            if (memoKey === _chartMemo) return;
            _chartMemo = memoKey;
            const height = 180;
            const margin = { top: 20, right: 30, bottom: 25, left: 45 };
            
            // Find boundaries
            const minVal = Math.min(...history);
            const maxVal = Math.max(...history);
            const rawRange = maxVal - minVal;
            const padding = rawRange === 0 ? 1000 : rawRange * 0.15;
            
            const min = Math.max(0, minVal - padding);
            const max = maxVal + padding;
            const range = max - min || 1;
            
            const xStep = (width - margin.left - margin.right) / Math.max(1, history.length - 1);
            
            const points = history.map((val, idx) => ({
                x: margin.left + idx * xStep,
                y: height - margin.bottom - ((val - min) / range) * (height - margin.top - margin.bottom),
                val: val
            }));
            
            // Build smooth Bezier path D
            let pathD = '';
            if (points.length === 1) {
                pathD = `M ${margin.left} ${points[0].y} L ${width - margin.right} ${points[0].y}`;
            } else {
                pathD = `M ${points[0].x} ${points[0].y}`;
                for (let i = 0; i < points.length - 1; i++) {
                    const p0 = points[i];
                    const p1 = points[i + 1];
                    const cpX1 = p0.x + (p1.x - p0.x) / 2;
                    const cpY1 = p0.y;
                    const cpX2 = p0.x + (p1.x - p0.x) / 2;
                    const cpY2 = p1.y;
                    pathD += ` C ${cpX1} ${cpY1}, ${cpX2} ${cpY2}, ${p1.x} ${p1.y}`;
                }
            }
            
            const areaD = pathD + ` L ${points[points.length - 1].x} ${height - margin.bottom} L ${points[0].x} ${height - margin.bottom} Z`;
            
            let svgHtml = `
            <svg width="100%" height="100%" viewBox="0 0 ${width} ${height}" style="overflow: visible;">
                <defs>
                    <linearGradient id="chart-glow" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="var(--cyan)" stop-opacity="0.22"></stop>
                        <stop offset="100%" stop-color="var(--cyan)" stop-opacity="0.0"></stop>
                    </linearGradient>
                    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="4" stdDeviation="5" flood-color="var(--cyan)" flood-opacity="0.25"></feDropShadow>
                    </filter>
                </defs>
                
                <!-- Y Gridlines & axis values -->
                <line x1="${margin.left}" y1="${margin.top}" x2="${width - margin.right}" y2="${margin.top}" stroke="rgba(255,255,255,0.03)" stroke-width="1"></line>
                <text x="${margin.left - 10}" y="${margin.top + 4}" fill="var(--text-dim)" font-size="9" text-anchor="end">${Math.round(max).toLocaleString()}</text>
                
                <line x1="${margin.left}" y1="${(height - margin.top - margin.bottom)/2 + margin.top}" x2="${width - margin.right}" y2="${(height - margin.top - margin.bottom)/2 + margin.top}" stroke="rgba(255,255,255,0.03)" stroke-width="1"></line>
                <text x="${margin.left - 10}" y="${(height - margin.top - margin.bottom)/2 + margin.top + 4}" fill="var(--text-dim)" font-size="9" text-anchor="end">${Math.round((max+min)/2).toLocaleString()}</text>
                
                <line x1="${margin.left}" y1="${height - margin.bottom}" x2="${width - margin.right}" y2="${height - margin.bottom}" stroke="rgba(255,255,255,0.06)" stroke-width="1"></line>
                <text x="${margin.left - 10}" y="${height - margin.bottom + 4}" fill="var(--text-dim)" font-size="9" text-anchor="end">${Math.round(min).toLocaleString()}</text>
                
                <!-- Area path fill -->
                <path d="${areaD}" fill="url(#chart-glow)"></path>
                
                <!-- Line path outline -->
                <path d="${pathD}" fill="none" stroke="var(--cyan)" stroke-width="3.5" filter="url(#shadow)" stroke-linecap="round"></path>
                <!-- Dashed accent for non-color trend discrimination -->
                <path d="${pathD}" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="1" stroke-dasharray="4 4" stroke-linecap="round"></path>
            `;

            points.forEach((pt, idx) => {
                svgHtml += `
                <circle cx="${pt.x}" cy="${pt.y}" r="5" fill="var(--bg)" stroke="var(--cyan)" stroke-width="2.5" class="chart-point" data-idx="${idx}" data-val="${pt.val}"></circle>
                `;
            });

            svgHtml += `</svg>`;
            container.innerHTML = svgHtml;

            const dots = container.querySelectorAll('.chart-point');
            const tooltip = document.getElementById('chart-tooltip');
            if (!tooltip) return;

            const showTooltip = (target) => {
                const idx = target.getAttribute('data-idx');
                const val = parseInt(target.getAttribute('data-val'));
                const cost = ((val * models[selectedModel].rate) / 1000000).toFixed(4);
                tooltip.style.opacity = '1';
                tooltip.innerHTML = `
                    <div style="font-weight:600;color:var(--cyan);margin-bottom:2px;font-family:var(--font-sans);">Run #${parseInt(idx)+1}</div>
                    <div style="font-size:12px;font-family:var(--font-sans);">Saved: <span style="color:var(--emerald);font-weight:600;">${val.toLocaleString()}</span> tokens</div>
                    <div style="font-size:11px;color:var(--text-dim);margin-top:2px;font-family:var(--font-mono);">Value: $${cost}</div>
                `;
                const rect = target.getBoundingClientRect();
                const containerRect = container.getBoundingClientRect();
                tooltip.style.left = (rect.left - containerRect.left + 12) + 'px';
                tooltip.style.top = (rect.top - containerRect.top - 55) + 'px';
                target.setAttribute('r', '7.5');
                target.style.cursor = 'pointer';
            };
            const hideTooltip = (target) => {
                tooltip.style.opacity = '0';
                target.setAttribute('r', '5');
            };

            dots.forEach(dot => {
                dot.setAttribute('tabindex', '0');
                dot.setAttribute('role', 'button');
                dot.setAttribute('aria-label',
                    `Run ${parseInt(dot.getAttribute('data-idx')) + 1}: ${parseInt(dot.getAttribute('data-val')).toLocaleString()} tokens saved`);
                dot.addEventListener('mouseenter', (e) => showTooltip(e.target));
                dot.addEventListener('mouseleave', (e) => hideTooltip(e.target));
                dot.addEventListener('focus',      (e) => showTooltip(e.target));
                dot.addEventListener('blur',       (e) => hideTooltip(e.target));
                dot.addEventListener('pointerdown',(e) => showTooltip(e.target));
            });
        }
    </script>
</body>
</html>
HTML_TEMPLATE

    local abs_path=""
    if [[ "$OSTYPE" == "darwin"* ]]; then
        abs_path=$(pwd)/$out_file
    else
        abs_path=$(readlink -f "$out_file" 2>/dev/null || pwd)/$out_file
    fi

    echo -e "\n  ${BGREEN}✨ Premium Offline-First Visual Dashboard Generated!${NC}"
    echo -e "  📂 Opening in browser: ${BBLUE}file://${abs_path}${NC}\n"

    if [[ "$OSTYPE" == "darwin"* ]]; then
        open "$abs_path" 2>/dev/null
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$abs_path" 2>/dev/null
    fi
}

# ─── STATS (JSON / CSV Exports) ─────────────────────────────────────────────
run_stats() {
    local format=$1
    
    if [ ! -d ".ai-memory" ]; then
        echo -e "${RED}❌ Tokenso not initialized in this project.${NC}"
        return 1
    fi
    load_or_init_stats

    local file_list
    file_list=$(list_source_files)
    local raw_words=0
    if [ -n "$file_list" ]; then
        raw_words=$(echo "$file_list" | tr '\n' '\0' | xargs -0 wc -w 2>/dev/null | tail -1 | awk '{print $1}')
    fi
    [ -z "$raw_words" ] && raw_words=0
    
    local map_words=0
    [ -f ".ai-memory/repo-map.txt" ] && map_words=$(wc -w < ".ai-memory/repo-map.txt")
    
    local raw_tokens=$(( raw_words * 13 / 10 ))
    local map_tokens=$(( map_words * 13 / 10 ))
    local saved_tokens=$(( raw_tokens - map_tokens ))
    [ $saved_tokens -lt 0 ] && saved_tokens=0
    
    local pct=0
    [ $raw_tokens -gt 0 ] && pct=$(( saved_tokens * 100 / raw_tokens ))
    
    local comp_ratio="0.0"
    if [ $map_tokens -gt 0 ]; then
        local ratio_tenth=$(( raw_tokens * 10 / map_tokens ))
        comp_ratio="$(( ratio_tenth / 10 )).$(( ratio_tenth % 10 ))"
    fi
    
    local cost_saved=$(cost_usd $saved_tokens)
    local cost_cum=$(cost_usd $CUMULATIVE_SAVED)
    
    if [ "$format" = "--json" ]; then
        cat << EOF
{
  "raw_tokens": $raw_tokens,
  "map_tokens": $map_tokens,
  "saved_tokens": $saved_tokens,
  "saved_percentage": $pct,
  "compression_ratio": "$comp_ratio",
  "saved_usd": $cost_saved,
  "cumulative_saved_tokens": $CUMULATIVE_SAVED,
  "cumulative_saved_usd": $cost_cum,
  "total_sessions": $SESSIONS
}
EOF
    elif [ "$format" = "--csv" ]; then
        echo "raw_tokens,map_tokens,saved_tokens,saved_percentage,compression_ratio,saved_usd,cumulative_saved_tokens,cumulative_saved_usd,total_sessions"
        echo "${raw_tokens},${map_tokens},${saved_tokens},${pct},${comp_ratio},${cost_saved},${CUMULATIVE_SAVED},${cost_cum},${SESSIONS}"
    elif [ "$format" = "--html" ]; then
        generate_html_dashboard
    else
        show_dashboard
    fi
}

# ─── STATE (Task Checker & Editor) ─────────────────────────────────────────
run_state() {
    local state_file=".ai-memory/state.md"
    
    if [ ! -f "$state_file" ]; then
        echo -e "${YELLOW}⚠️  State file ($state_file) does not exist.${NC}"
        if [ -t 0 ]; then
            read -p "  Would you like to initialize it now? [Y/n]: " init_choice
            if [[ ! "$init_choice" =~ ^[Nn]$ ]]; then
                mkdir -p .ai-memory
                cat > "$state_file" << 'EOF'
# AI Memory State

## Completed Tasks
- [x] Initialized smart search memory and Tokenso

## Next Actions
- [ ] Explore codebase modules
- [ ] Set up project specific rules

## Key Context & Architecture
- (Add crucial project facts here to avoid re-reading files)
EOF
                echo -e "  ${GREEN}✓ State file initialized!${NC}"
            else
                return 1
            fi
        else
            return 1
        fi
    fi

    echo -e "${BCYAN}======================================================${NC}"
    echo -e "${BGREEN}🧠 AI Memory State — Task Tracker${NC}"
    echo -e "${BCYAN}======================================================${NC}\n"

    while IFS= read -r line || [ -n "$line" ]; do
        local trimmed=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
        
        if [[ "$trimmed" =~ ^#+[[:space:]]+(.*) ]]; then
            local header="${BASH_REMATCH[1]}"
            echo ""
            echo -e "  ${BOLD}${BCYAN}[ $header ]${NC}"
            echo -e "  ${DIM}─────────────────────────────────────────${NC}"
        elif [[ "$trimmed" =~ ^-[[:space:]]+\[x\][[:space:]]*(.*) ]]; then
            local task="${BASH_REMATCH[1]}"
            echo -e "  ${GREEN}✓${NC}  ${DIM}${task}${NC}"
        elif [[ "$trimmed" =~ ^-[[:space:]]+\[[[:space:]]*\][[:space:]]*(.*) ]]; then
            local task="${BASH_REMATCH[1]}"
            echo -e "  ${YELLOW}○${NC}  ${task}"
        elif [[ "$trimmed" =~ ^-[[:space:]]+(.*) ]]; then
            local item="${BASH_REMATCH[1]}"
            echo -e "  ${BLUE}•${NC}  ${item}"
        elif [[ "$trimmed" =~ ^\![[:space:]]+(.*) ]]; then
            local milestone="${BASH_REMATCH[1]}"
            echo ""
            echo -e "  ${YELLOW}┌───────────────────────────────────────────────┐${NC}"
            echo -e "  ${YELLOW}│${NC}  ${BGREEN}💬 Milestone:${NC} ${BOLD}${milestone}${NC}"
            echo -e "  ${YELLOW}└───────────────────────────────────────────────┘${NC}"
        elif [ -n "$trimmed" ]; then
            echo -e "  $trimmed"
        fi
    done < "$state_file"
    echo ""

    if [ -t 0 ]; then
        read -p "  Would you like to edit your AI memory state file? [y/N]: " edit_choice
        if [[ "$edit_choice" =~ ^[yY](es)?$ ]]; then
            local editor="nano"
            if [ -n "$EDITOR" ]; then
                editor="$EDITOR"
            elif command -v nano &>/dev/null; then
                editor="nano"
            elif command -v vim &>/dev/null; then
                editor="vim"
            elif command -v vi &>/dev/null; then
                editor="vi"
            fi
            
            echo -e "  ${CYAN}Launching $editor for $state_file...${NC}"
            sleep 0.5
            $editor "$state_file"
            
            echo -e "\n  ${GREEN}✓ State file successfully updated!${NC}"
            # Recursive display refresh
            run_state
        fi
    fi
}

# ─── MAP (Folder Structure Visualizer) ─────────────────────────────────────
run_map() {
    local map_file=".ai-memory/repo-map.txt"
    
    if [ ! -f "$map_file" ]; then
        echo -e "${YELLOW}⚠️  Repository map does not exist yet.${NC}"
        echo -e "  ${BLUE}Generating new codebase map...${NC}"
        if [ -f ".ai-memory/scripts/init-smart-search.sh" ]; then
            bash .ai-memory/scripts/init-smart-search.sh . &>/dev/null
        else
            echo -e "${RED}❌ Map generation script not found. Run 'tokenso install' first.${NC}"
            return 1
        fi
        echo -e "  ${GREEN}✓ Map successfully generated!${NC}\n"
    fi

    local bytes=$(wc -c < "$map_file" | tr -d ' ')
    local words=$(wc -w < "$map_file" | tr -d ' ')
    local tokens=$(( words * 13 / 10 ))

    echo -e "${BCYAN}======================================================${NC}"
    echo -e "${BGREEN}🗺  Repository Map — Codebase Blueprint${NC}"
    echo -e "  ${DIM}Size: $bytes bytes  |  Est. Context Weight: ~$tokens tokens${NC}"
    echo -e "${BCYAN}======================================================${NC}\n"

    while IFS= read -r line || [ -n "$line" ]; do
        local colorized="$line"
        
        # Color tree connectors in DIM CYAN
        colorized=$(echo "$colorized" | sed -E "s/(├──|└──|│)/${DIM}${CYAN}\1${NC}/g")
        
        # Color folders in BOLD BLUE
        if [[ "$line" =~ .*/$ ]]; then
            colorized=$(echo "$colorized" | sed -E "s/([a-zA-Z0-9_\.-]+\/)/${BBLUE}\1${NC}/g")
        else
            # Color code files in BRIGHT CYAN
            colorized=$(echo "$colorized" | sed -E "s/([a-zA-Z0-9_\.-]+\.[a-zA-Z0-9]+)/${CYAN}\1${NC}/g")
        fi
        
        echo -e "  $colorized"
    done < "$map_file"
    echo ""
}

# ─── CLEAN (Cache Wiper) ───────────────────────────────────────────────────
run_clean() {
    echo -e "${BRED}======================================================${NC}"
    echo -e "${BRED}⚠️  WIPE TOKENS CACHE & STORAGE${NC}"
    echo -e "${BRED}======================================================${NC}\n"
    
    echo -e "  This action will permanently delete:"
    echo -e "    ${RED}●${NC} Codebase repository map (${CYAN}.ai-memory/repo-map.txt${NC})"
    echo -e "    ${RED}●${NC} Token savings statistics and history (${CYAN}.ai-memory/optimizer-stats.json${NC})"
    echo -e "    ${RED}●${NC} AI Memory milestone checklist (${CYAN}.ai-memory/state.md${NC})"
    echo ""
    echo -e "  ${YELLOW}Note: Configuration rules (like .geminirules, .cursorrules) will remain untouched.${NC}"
    echo ""

    if [ -t 0 ]; then
        read -p "  Are you absolutely sure you want to proceed? [y/N]: " clean_confirm
        if [[ "$clean_confirm" =~ ^[yY](es)?$ ]]; then
            echo -e "\n  ${BLUE}Cleaning cached optimizer storage...${NC}"
            
            [ -f ".ai-memory/repo-map.txt" ] && rm ".ai-memory/repo-map.txt"
            [ -f ".ai-memory/optimizer-stats.json" ] && rm ".ai-memory/optimizer-stats.json"
            [ -f ".ai-memory/state.md" ] && rm ".ai-memory/state.md"
            [ -d ".ai-memory/scripts" ] && rm -rf ".ai-memory/scripts"
            
            if [ -d ".ai-memory" ] && [ -z "$(ls -A .ai-memory)" ]; then
                rmdir ".ai-memory"
            fi
            
            sleep 0.5
            echo -e "  ${GREEN}✓ Cache successfully cleared! Run 'tokenso install' or 'tokenso run' to re-initialize.${NC}\n"
        else
            echo -e "\n  ${GREEN}Clean action aborted. Storage preserved.${NC}\n"
        fi
    else
        echo -e "  ${RED}Wipe cancelled (non-interactive shell detected).${NC}\n"
    fi
}

# ─── RESET ──────────────────────────────────────────────────────────────────
run_reset() {
    if [ -f ".ai-memory/optimizer-stats.json" ]; then
        local installed_date
        installed_date=$(_json_string ".ai-memory/optimizer-stats.json" installed)
        [ -z "$installed_date" ] && installed_date=$(date +"%Y-%m-%d")
        cat > ".ai-memory/optimizer-stats.json" << EOF
{
  "schema": 1,
  "version": "$VERSION",
  "installed": "$installed_date",
  "sessions": 0,
  "cumulative_saved": 0,
  "last_run": "$(date +"%Y-%m-%d %H:%M")",
  "history": []
}
EOF
        echo -e "${GREEN}✅ Cumulative stats and history cleared for this project (installation date preserved).${NC}"
    else
        echo -e "${YELLOW}No stats file found.${NC}"
    fi
}

# ─── UPDATE ─────────────────────────────────────────────────────────────────
run_update() {
    echo -e "${BLUE}Pulling latest version from GitHub...${NC}"
    local cmd_path=$(which tokenso 2>/dev/null)
    if [ -z "$cmd_path" ]; then
        echo -e "${RED}❌ Global 'tokenso' command not found in PATH.${NC}"
        echo -e "   Please run ${CYAN}bash install.sh${NC} to install or reinstall it."
        return 1
    fi
    local install_dir=$(dirname "$cmd_path")
    if [ -w "$install_dir" ] && [ -w "$cmd_path" ]; then
        curl -sSL "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/bin/tokenso" -o "$cmd_path"
        chmod +x "$cmd_path"
    else
        echo -e "${YELLOW}🔑 Sudo privileges required to update $cmd_path...${NC}"
        sudo curl -sSL "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/bin/tokenso" -o "$cmd_path"
        sudo chmod +x "$cmd_path"
    fi
    echo -e "${GREEN}✅ Updated to latest version!${NC}"
    tokenso --version
}

# ─── VERSION ────────────────────────────────────────────────────────────────
show_version() {
    echo "tokenso v$VERSION"
}

# ─── RUN (GUI INTERACTIVE ENGINE) ───────────────────────────────────────────
print_mindmap_frame() {
    local step=$1  # 1 to 9
    
    # Colors
    local c_ws="${BCYAN}"
    local c_cr="${MAGENTA}"
    local c_ms="${YELLOW}"
    local c_sm="${BGREEN}"
    local p_col="${DIM}"
    
    local l2_left="│"
    local l2_right="│"
    local l11_left="│"
    local l11_right="│"
    
    local l4_c1="└"
    local l4_h1="───────────────────"
    local l4_c2="┐"
    local l4_c3="┌"
    local l4_h2="───────────────────"
    local l4_c4="┘"
    
    local l10_c1="┌"
    local l10_h1="───────────────────"
    local l10_c2="┘"
    local l10_c3="└"
    local l10_h2="───────────────────"
    local l10_c4="┐"
    
    local l5_left="│"
    local l5_right="│"
    local l9_left="│"
    local l9_right="│"
    
    local l6_left="▼"
    local l6_right="▼"
    local l8_left="▲"
    local l8_right="▲"
    
    local core="${BBLUE}[ TOKENSO CORE ]${NC}"
    local syn="${YELLOW}⚡${p_col}"
    
    case $step in
        1)
            l2_left="${syn}"
            l2_right="${syn}"
            l11_left="${syn}"
            l11_right="${syn}"
            ;;
        2)
            l4_c1="${syn}"
            l4_c4="${syn}"
            l10_c1="${syn}"
            l10_c4="${syn}"
            ;;
        3)
            l4_h1="─────────${syn}─────────"
            l4_h2="─────────${syn}─────────"
            l10_h1="─────────${syn}─────────"
            l10_h2="─────────${syn}─────────"
            ;;
        4)
            l4_c2="${syn}"
            l4_c3="${syn}"
            l10_c2="${syn}"
            l10_c3="${syn}"
            ;;
        5)
            l5_left="${syn}"
            l5_right="${syn}"
            l9_left="${syn}"
            l9_right="${syn}"
            ;;
        6)
            l6_left="${syn}"
            l6_right="${syn}"
            l8_left="${syn}"
            l8_right="${syn}"
            ;;
        7) core="${BGREEN}[ TOKENSO CORE ]${NC}" ;;
        8) core="${BCYAN}[ TOKENSO CORE ]${NC}" ;;
        9) core="${YELLOW}[ TOKENSO CORE ]${NC}" ;;
    esac
    
    echo -e "     ${c_ws}[Workspace Code]${NC}                            ${c_cr}[Context Rules]${NC}"
    echo -e "            ${p_col}${l2_left}${NC}                                           ${p_col}${l2_right}${NC}"
    echo -e "            ${p_col}▼${NC}                                           ${p_col}▼${NC}"
    echo -e "            ${p_col}${l4_c1}${l4_h1}${l4_c2}${NC}   ${p_col}${l4_c3}${l4_h2}${l4_c4}${NC}"
    echo -e "                                 ${p_col}${l5_left}${NC}   ${p_col}${l5_right}${NC}"
    echo -e "                                 ${p_col}${l6_left}${NC}   ${p_col}${l6_right}${NC}"
    echo -e "                         ${core}"
    echo -e "                                 ${p_col}${l8_left}${NC}   ${p_col}${l8_right}${NC}"
    echo -e "                                 ${p_col}${l9_left}${NC}   ${p_col}${l9_right}${NC}"
    echo -e "            ${p_col}${l10_c1}${l10_h1}${l10_c2}${NC}   ${p_col}${l10_c3}${l10_h2}${l10_c4}${NC}"
    echo -e "            ${p_col}▲${NC}                                           ${p_col}▲${NC}"
    echo -e "            ${p_col}${l11_left}${NC}                                           ${p_col}${l11_right}${NC}"
    echo -e "     ${c_ms}[Memory State]${NC}                             ${c_sm}[Semantic Map]${NC}"
}

