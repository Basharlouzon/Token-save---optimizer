        cat > ".ai-memory/optimizer-stats.json" << EOF
{
  "schema": 1,
  "version": "$VERSION",
  "installed": "$INSTALL_DATE",
  "sessions": 0,
  "cumulative_saved": 0,
  "last_run": "$INSTALL_DATE",
  "history": []
}
EOF
    fi

    echo ""
    echo -e "${BBLUE}======================================================${NC}"
    echo -e "${BGREEN}🎉 All done!${NC}"
    echo -e "  Run ${CYAN}tokenso${NC} to see your live Tokenso dashboard."
    echo -e "  Star the repo ⭐  ${DIM}github.com/Basharlouzon/Token-save---optimizer${NC}"
    echo -e "${BBLUE}======================================================${NC}\n"
}

# ─── SAVE & UPDATE ──────────────────────────────────────────────────────────
run_save() {
    local silent=false
    local quiet=false
    local message=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --silent|-s)
                silent=true
                shift
                ;;
            --quiet|-q)
                quiet=true
                silent=true
                shift
                ;;
            -m|--message)
                message="$2"
                shift 2
                ;;
            *)
                if [ -n "$message" ]; then
                    message="$message $1"
                else
                    message="$1"
                fi
                shift
                ;;
        esac
    done
    
    if [ "$quiet" = true ]; then
        exec 3>/dev/null 1>&3 2>&3
    fi

    if [ ! -d ".ai-memory" ]; then
        if [ "$silent" = true ]; then
            return 1
        fi

        echo -e "${YELLOW}⚠️  .ai-memory is not initialized in this project.${NC}"
        [ -t 0 ] || exec < /dev/tty
        read -p "  Would you like to initialize it now? [Y/n]: " init_choice
        if [[ "$init_choice" =~ ^[Nn]$ ]]; then
            echo -e "  ${RED}Aborting. Save requires initialization.${NC}"
            return 1
        fi

        echo ""
        run_install

        if [ ! -d ".ai-memory" ]; then
            echo -e "${RED}❌ Initialization failed or cancelled.${NC}"
            return 1
        fi
    fi

    if [ "$silent" = false ]; then
        echo -e "${BLUE}⚙  Updating repository map and Tokenso statistics...${NC}"
    fi
    
    if [ -f ".ai-memory/scripts/init-smart-search.sh" ]; then
        bash .ai-memory/scripts/init-smart-search.sh . &>/dev/null
    else
        mkdir -p .ai-memory/scripts
        if [ -f "scripts/init-smart-search.sh" ]; then
            cp scripts/init-smart-search.sh .ai-memory/scripts/init-smart-search.sh
            chmod +x .ai-memory/scripts/init-smart-search.sh
        else
            curl -sSL "https://raw.githubusercontent.com/Basharlouzon/Token-save---optimizer/master/scripts/init-smart-search.sh" \
                 -o .ai-memory/scripts/init-smart-search.sh
            chmod +x .ai-memory/scripts/init-smart-search.sh
        fi
        bash .ai-memory/scripts/init-smart-search.sh . &>/dev/null
    fi

    load_or_init_stats

    local raw_words=0
    local file_list
    file_list=$(list_source_files)
    if [ -n "$file_list" ]; then
        raw_words=$(echo "$file_list" | tr '\n' '\0' | xargs -0 wc -w 2>/dev/null | tail -1 | awk '{print $1}')
    else
        raw_words=0
    fi
    [ -z "$raw_words" ] && raw_words=0

    local map_words=0
    [ -f ".ai-memory/repo-map.txt" ] && map_words=$(wc -w < ".ai-memory/repo-map.txt")

    local raw_tokens=$(( raw_words * 13 / 10 ))
    local map_tokens=$(( map_words * 13 / 10 ))
    local saved_tokens=$(( raw_tokens - map_tokens ))
    [ $saved_tokens -lt 0 ] && saved_tokens=0

    local next_sessions=$(( SESSIONS + 1 ))
    local next_saved=$(( CUMULATIVE_SAVED + saved_tokens ))
    
    save_stats "$next_sessions" "$next_saved" "$saved_tokens"

    # Append milestone note
    if [ -z "$message" ] && [ "$silent" = false ] && [ -t 0 ]; then
        echo ""
        echo -e "  ${YELLOW}💡 Interactive Milestone Note${NC}"
        echo -e "     Add a brief description of the current milestone/changes to log in state.md"
        echo -e "     (e.g., 'Implemented auth flow' or press Enter to skip):"
        read -p "     📝 Note: " message
        message=$(echo "$message" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    fi

    if [ -n "$message" ]; then
        echo -e "! $message" >> ".ai-memory/state.md"
    fi
    
    if [ "$silent" = false ]; then
        local cost_saved=$(cost_usd $saved_tokens)
        echo -e "${GREEN}✅ Repository map successfully updated!${NC}"
        echo -e "   📂 Project Map: ${CYAN}.ai-memory/repo-map.txt${NC}"
        [ -n "$message" ] && echo -e "   📝 Added memory note: ${CYAN}! $message${NC}"
        echo -e "   🧠 Saved ${YELLOW}$(fmt_num $saved_tokens)${NC} tokens (\$${cost_saved} est. savings) in this update!"
    fi
}

# ─── SEARCH (Zero-Waste Code Search) ──────────────────────────────────────────
run_search() {
    local query="$1"
    if [ -z "$query" ]; then
        echo -e "${RED}❌ Search query cannot be empty.${NC}"
        echo -e "   Usage: ${CYAN}tokenso search <query>${NC}"
        return 1
    fi

    if [ ! -d ".ai-memory" ]; then
        echo -e "${RED}❌ Tokenso not initialized in this project.${NC}"
        return 1
    fi

    echo -e "${BCYAN}======================================================${NC}"
    echo -e "${BGREEN}🔍 Zero-Waste Code Search${NC}  ${DIM}Query: '${query}'${NC}"
    echo -e "${BCYAN}======================================================${NC}\n"

    # 1. Fuzzy Path Search
    local map_file=".ai-memory/repo-map.txt"
    if [ -f "$map_file" ]; then
        echo -e "  ${BOLD}${BCYAN}[ 📁 Codebase Blueprint Matches ]${NC}"
        echo -e "  ${DIM}─────────────────────────────────────────${NC}"
        local map_matches=$(grep -i -F "$query" "$map_file" 2>/dev/null || true)
        if [ -n "$map_matches" ]; then
            while IFS= read -r line; do
                local trimmed=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
                if [ -n "$trimmed" ]; then
                    local highlighted=$(echo "$trimmed" | perl -pe "s/(\Q$query\E)/${YELLOW}\$1${NC}/gi")
                    echo -e "    ${CYAN}•${NC} ${highlighted}"
                fi
            done <<< "$map_matches"
        else
            echo -e "    ${DIM}No matching file paths in repository map.${NC}"
        fi
        echo ""
    fi

    # 2. High-Density Snippet Scan
    echo -e "  ${BOLD}${BCYAN}[ 📝 Source Code Matches (Max 15) ]${NC}"
    echo -e "  ${DIM}─────────────────────────────────────────${NC}"

    local file_list
    file_list=$(list_source_files)
    if [ -z "$file_list" ]; then
        echo -e "    ${DIM}No active source files found in workspace.${NC}\n"
        return 0
    fi

    local match_count=0
    local searched_files=0
    local max_matches=15
    local start_time=$(date +%s 2>/dev/null || date +%S)

    local temp_matches=".ai-memory/temp_search_matches.txt"
    touch "$temp_matches"
    > "$temp_matches"

    if command -v rg &>/dev/null; then
        echo "$file_list" | tr '\n' '\0' | xargs -0 rg -i -n --no-heading --with-filename -F "$query" > "$temp_matches" 2>/dev/null || true
    else
        echo "$file_list" | tr '\n' '\0' | xargs -0 grep -i -H -n -F "$query" > "$temp_matches" 2>/dev/null || true
    fi

    local total_matches=$(wc -l < "$temp_matches" | tr -d ' ')
    if [ "$total_matches" -eq 0 ]; then
        echo -e "    ${DIM}No matches found in active source code files.${NC}\n"
        rm -f "$temp_matches"
        return 0
    fi

    local printed=0
    local last_file=""
    while IFS= read -r line && [ $printed -lt $max_matches ]; do
        if [[ "$line" =~ ^([^:]+):([0-9]+):(.*)$ ]]; then
            local file="${BASH_REMATCH[1]}"
            local line_num="${BASH_REMATCH[2]}"
            local content="${BASH_REMATCH[3]}"
            
            content=$(echo "$content" | sed -e 's/^[[:space:]]*//')
            local highlighted_content=$(echo "$content" | perl -pe "s/(\Q$query\E)/${YELLOW}\$1${NC}${DIM}/gi")
            
            if [ "$file" != "$last_file" ]; then
                [ -n "$last_file" ] && echo ""
                echo -e "  ${BGREEN}📂 ${file}${NC}"
                last_file="$file"
            fi
            echo -e "     ${BOLD}Line ${line_num}:${NC} ${DIM}${highlighted_content}${NC}"
            printed=$(( printed + 1 ))
        fi
    done < "$temp_matches"

    [ $printed -gt 0 ] && echo ""

    rm -f "$temp_matches"

    local end_time=$(date +%s 2>/dev/null || date +%S)
    local elapsed=$(( end_time - start_time ))
    [ $elapsed -lt 0 ] && elapsed=0

    local files_count=$(echo "$file_list" | wc -l | tr -d ' ')
    
    echo -e "  ${DIM}Searched $files_count files | Found $total_matches matches | Showing top $printed | Done in ${elapsed}s${NC}\n"
}

# ─── PREMIUM DASHBOARD GENERATOR ────────────────────────────────────────────
generate_html_dashboard() {
    local out_file="tokenso-dashboard.html"
    
    load_or_init_stats

    local file_list
    file_list=$(list_source_files)
    local files_count=0
    local raw_words=0
    if [ -n "$file_list" ]; then
        files_count=$(echo "$file_list" | wc -l | tr -d ' ')
        raw_words=$(echo "$file_list" | tr '\n' '\0' | xargs -0 wc -w 2>/dev/null | tail -1 | awk '{print $1}')
    fi
    [ -z "$raw_words" ] && raw_words=0
    
    local map_words=0
    [ -f ".ai-memory/repo-map.txt" ] && map_words=$(wc -w < ".ai-memory/repo-map.txt")
    
    local raw_tokens=$(( raw_words * 13 / 10 ))
    local map_tokens=$(( map_words * 13 / 10 ))
    local saved_tokens=$(( raw_tokens - map_tokens ))
    [ $saved_tokens -lt 0 ] && saved_tokens=0
    
    local pct=0
    [ $raw_tokens -gt 0 ] && pct=$(( saved_tokens * 100 / raw_tokens ))
    
    local comp_ratio="0.0"
    if [ $map_tokens -gt 0 ]; then
        local ratio_tenth=$(( raw_tokens * 10 / map_tokens ))
        comp_ratio="$(( ratio_tenth / 10 )).$(( ratio_tenth % 10 ))"
    fi
    
    local cost_saved=$(cost_usd $saved_tokens)
    local cost_cum=$(cost_usd $CUMULATIVE_SAVED)
    local date_exported=$(date +"%Y-%m-%d %H:%M")
    local project_name=$(basename "$(pwd)")
    local active_agents=$(detect_tools)
    
    # Format history as JSON array
    local history_json="[]"
    local hist
    hist=$(_json_history ".ai-memory/optimizer-stats.json")
    if [ -n "$hist" ]; then
        history_json="[$(echo "$hist" | tr ' ' ',' | sed 's/,,*/,/g; s/^,//; s/,$//')]"
    fi
    
    # Format milestones as JSON array
    local milestones_json="[]"
    if [ -f ".ai-memory/state.md" ]; then
        local milestones=()
        while IFS= read -r line || [ -n "$line" ]; do
            if [[ "$line" =~ ^\![[:space:]]*(.*) ]]; then
                local ms=$(echo "${BASH_REMATCH[1]}" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g')
                milestones+=("\"$ms\"")
            fi
        done < ".ai-memory/state.md"
        
        if [ ${#milestones[@]} -gt 0 ]; then
            local joined=""
            for ((i=0; i<${#milestones[@]}; i++)); do
                joined="${joined}${milestones[$i]}"
                if [ $i -lt $(( ${#milestones[@]} - 1 )) ]; then
                    joined="${joined}, "
                fi
            done
            milestones_json="[$joined]"
        fi
    fi

    cat << EOF > "$out_file"
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tokenso — Context Optimizer Dashboard</title>
    
    <!-- Outfit & Fira Code Fonts (with system-font fallback so the dashboard
         renders fully even offline). -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap"
          rel="stylesheet"
          media="all"
          onerror="this.media='print'">

    <script>
    window.TOKENSO_DATA = {
        projectName: "${project_name}",
        dateExported: "${date_exported}",
        activeAgents: "${active_agents}",
        filesCount: ${files_count},
        rawTokens: ${raw_tokens},
        mapTokens: ${map_tokens},
        savedTokens: ${saved_tokens},
        pct: ${pct},
        compRatio: "${comp_ratio}",
        costSaved: "${cost_saved}",
        sessions: ${SESSIONS},
        cumulativeSaved: ${CUMULATIVE_SAVED},
        costCum: "${cost_cum}",
        history: ${history_json},
        milestones: ${milestones_json}
    };
    </script>
EOF

    cat << 'HTML_TEMPLATE' >> "$out_file"
    <style>
        :root {
            --bg: #070913;
            --card-bg: rgba(20, 24, 38, 0.45);
            --border-color: rgba(255, 255, 255, 0.05);
            --cyan: #00f0ff;
            --emerald: #00e676;
            --purple: #bf5af2;
            --text: #f5f5f7;
            --text-dim: #9898a3;
            --gold: #ffd60a;
            
            --font-sans: 'Outfit', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --font-mono: 'Fira Code', ui-monospace, SFMono-Regular, Menlo, Consolas, 'Courier New', monospace;
        }
        
        * {
            box-sizing: border-box;
            outline: none;
        }
        
        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: var(--font-sans);
            margin: 0;
            padding: 0;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(0, 240, 255, 0.04) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(191, 90, 242, 0.03) 0%, transparent 40%);
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
            z-index: 2;
            position: relative;
        }
        
        /* Glassmorphic Panel styling */
        .glass-panel {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.35);
            position: relative;
