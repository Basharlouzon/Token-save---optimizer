        printf "\033[13A"
        print_mindmap_frame $step
        sleep 0.15
    done
    echo ""

    echo -e "  ${BGREEN}✨ Cognitive Mindmap Successfully Integrated!${NC}"
    echo -e "  Estimated savings vectors initialized at ${YELLOW}~85% context compression${NC}."
    echo ""

    echo -e "  ${BOLD}┌────────────────────────────────────────────────────────┐${NC}"
    echo -e "  ${BOLD}│  ❓ Connect nodes and save Tokenso optimized map? [Y/n] │${NC}"
    echo -e "  ${BOLD}└────────────────────────────────────────────────────────┘${NC}"
    
    if [ -t 0 ]; then
        read -n 1 -r -p "  Selection: " response
        echo ""
    else
        response="Y"
    fi
    
    if [[ "$response" =~ ^[Nn]$ ]]; then
        echo -e "\n  ${YELLOW}Skipping save. Showing dashboard...${NC}"
        sleep 0.6
        show_dashboard
    else
        echo -e "\n  ${GREEN}Saving and building optimized mindmap...${NC}"
        sleep 0.4
        run_save --silent
        echo -e "  ${GREEN}✓ Map and stats successfully saved!${NC}"
        sleep 0.8
        show_dashboard
    fi
}

# ─── ROUTER ─────────────────────────────────────────────────────────────────
_QUIET=false
if [[ "$1" == "--quiet" || "$1" == "-q" ]]; then
    _QUIET=true
    shift
fi

case "$1" in
    run)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_gui "$@"
        ;;
    install)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_install "$@"
        ;;
    save)
        shift
        run_save "$@"
        ;;
    search)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_search "$@"
        ;;
    stats)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_stats "$@"
        ;;
    state)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_state "$@"
        ;;
    map)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_map "$@"
        ;;
    clean)
        shift
        if [ "$_QUIET" = true ]; then exec 3>/dev/null 1>&3 2>&3; fi
        run_clean "$@"
        ;;
    reset)            run_reset ;;
    update)           run_update ;;
    --version|-v)     show_version ;;
    help|--help|-h)   show_dashboard ;;
    "")               show_dashboard ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_dashboard
        exit 1
        ;;
esac
